{
	"name": "next-tutorial",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"analyze": "ANALYZE=true next build --webpack",
		"start": "next start",
		"format": "biome check --write .",
		"lint": "biome lint --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "npx tsx lib/db/seed.ts",
		"test": "bun run test:unit && bun run test:e2e",
		"test:unit": "npx vitest run",
		"test:unit:watch": "npx vitest",
		"test:e2e": "npx playwright test",
		"test:e2e:ui": "npx playwright test --ui",
		"test:e2e:build": "CI=1 npx playwright test",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "bunx lint-staged"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css}": "biome check --write --no-errors-on-unmatched"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.0",
		"@hono/zod-validator": "^0.7.6",
		"@hookform/resolvers": "^5.2.2",
		"@mdx-js/react": "^3.1.1",
		"@next/mdx": "^16.2.4",
		"@tanstack/react-query": "^5.99.0",
		"better-sqlite3": "^12.9.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"dayjs": "^1.11.20",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.14",
		"lucide-react": "^1.8.0",
		"motion": "^12.38.0",
		"next": "16.2.4",
		"next-intl": "^4.9.1",
		"next-themes": "^0.4.6",
		"nuqs": "^2.8.9",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-hook-form": "^7.72.1",
		"shadcn": "^4.2.0",
		"sharp": "^0.34.5",
		"shiki": "^4.0.2",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@next/bundle-analyzer": "^16.2.4",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/postcss": "^4",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"babel-plugin-react-compiler": "^1.0.0",
		"drizzle-kit": "^0.31.10",
		"lint-staged": "^16.4.0",
		"simple-git-hooks": "^2.13.1",
		"tailwindcss": "^4",
		"typescript": "^5",
		"vitest": "^4.1.4"
	},
	"ignoreScripts": [
		"sharp",
		"unrs-resolver"
	],
	"trustedDependencies": [
		"sharp",
		"unrs-resolver"
	]
}
